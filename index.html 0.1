<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AquaCalc CR</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
--bg: #0a1628;
--surface: #0f2040;
--surface2: #142a4f;
--green: #00c896;
--blue: #0099ff;
--yellow: #f0a500;
--text: #e8edf5;
--text2: #8899b0;
--danger: #ff4466;
--border: rgba(255,255,255,0.08);
--radius: 14px;
}
* { margin:0; padding:0; box-sizing:border-box; }
body {
font-family: 'DM Sans', sans-serif;
background: var(--bg);
color: var(--text);
min-height: 100vh;
overflow-x: hidden;
}
h1,h2,h3,h4,.tab-btn,.species-card-name {
font-family: 'Syne', sans-serif;
}
.mono {
font-family: 'DM Mono', monospace;
}

/* SCROLLBAR */
::-webkit-scrollbar { width:6px; }
::-webkit-scrollbar-track { background:var(--bg); }
::-webkit-scrollbar-thumb { background:var(--surface2); border-radius:3px; }

/* AUTH SCREEN */
#auth-screen {
display:flex; align-items:center; justify-content:center;
min-height:100vh; padding:20px;
}
.auth-container {
background:var(--surface);
border:1px solid var(--border);
border-radius:var(--radius);
padding:40px 32px;
width:100%; max-width:420px;
}
.auth-logo {
text-align:center; margin-bottom:28px;
}
.auth-logo h1 {
font-size:28px; color:var(--green);
}
.auth-logo p {
color:var(--text2); font-size:13px; margin-top:4px;
}
.auth-tabs {
display:flex; gap:0; margin-bottom:24px;
background:var(--bg); border-radius:10px; padding:4px;
}
.auth-tab {
flex:1; text-align:center; padding:10px;
border-radius:8px; cursor:pointer;
font-family:'Syne',sans-serif; font-weight:600;
font-size:14px; color:var(--text2);
transition:.2s;
}
.auth-tab.active {
background:var(--surface2); color:var(--green);
}
.form-group {
margin-bottom:16px;
}
.form-group label {
display:block; font-size:12px; color:var(--text2);
margin-bottom:6px; font-weight:500;
}
.form-group input, .form-group select, .form-group textarea {
width:100%; padding:12px 14px;
background:var(--bg); border:1px solid var(--border);
border-radius:10px; color:var(--text);
font-family:'DM Sans',sans-serif; font-size:14px;
outline:none; transition:.2s;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
border-color:var(--green);
}
.btn {
width:100%; padding:14px;
border:none; border-radius:10px;
font-family:'Syne',sans-serif; font-weight:700;
font-size:15px; cursor:pointer;
transition:.2s;
}
.btn-primary {
background:linear-gradient(135deg,var(--green),#00a87e);
color:#fff;
}
.btn-primary:hover { opacity:.9; }
.btn-danger {
background:var(--danger); color:#fff;
}
.btn-secondary {
background:var(--surface2); color:var(--text);
border:1px solid var(--border);
}
.btn-small {
width:auto; padding:8px 16px; font-size:12px;
}
.auth-error {
color:var(--danger); font-size:12px;
margin-top:8px; text-align:center;
}

/* MAIN APP */
#app-screen { display:none; }
.header {
background:var(--surface);
border-bottom:1px solid var(--border);
padding:12px 20px;
display:flex; align-items:center; justify-content:space-between;
position:sticky; top:0; z-index:100;
}
.header-left h2 {
font-size:18px; color:var(--green);
}
.header-left p {
font-size:11px; color:var(--text2); margin-top:2px;
}
.header-right {
display:flex; align-items:center; gap:10px;
}
.header-right .user-info {
text-align:right;
}
.header-right .user-info span {
display:block; font-size:12px; color:var(--text);
font-weight:600;
}
.header-right .user-info small {
font-size:10px; color:var(--text2);
}
.btn-logout {
background:transparent; border:1px solid var(--border);
color:var(--text2); padding:8px 12px;
border-radius:8px; cursor:pointer; font-size:12px;
font-family:'DM Sans',sans-serif;
transition:.2s;
}
.btn-logout:hover { border-color:var(--danger); color:var(--danger); }

/* TABS */
.tabs {
display:flex; gap:0;
background:var(--surface);
border-bottom:1px solid var(--border);
overflow-x:auto; padding:0 12px;
-webkit-overflow-scrolling:touch;
}
.tab-btn {
padding:14px 16px; white-space:nowrap;
font-size:12px; font-weight:600;
color:var(--text2); cursor:pointer;
border-bottom:3px solid transparent;
transition:.2s; flex-shrink:0;
}
.tab-btn.active {
color:var(--green);
border-bottom-color:var(--green);
}
.tab-btn:hover { color:var(--text); }

.tab-content { display:none; padding:16px; max-width:900px; margin:0 auto; }
.tab-content.active { display:block; }

/* CARDS */
.card {
background:var(--surface);
border:1px solid var(--border);
border-radius:var(--radius);
padding:20px; margin-bottom:16px;
}
.card-title {
font-size:15px; font-weight:700;
margin-bottom:14px; display:flex;
align-items:center; gap:8px;
}
.card-title .dot {
width:8px; height:8px; border-radius:50%;
}

/* SPECIES CARDS */
.species-grid {
display:grid;
grid-template-columns: repeat(auto-fill, minmax(130px,1fr));
gap:10px; margin-bottom:20px;
}
.species-card {
background:var(--bg);
border:2px solid var(--border);
border-radius:12px;
padding:14px 10px;
text-align:center; cursor:pointer;
transition:.2s; position:relative;
}
.species-card:hover { border-color:var(--blue); }
.species-card.selected { border-color:var(--green); background:rgba(0,200,150,0.05); }
.species-card .emoji { font-size:32px; display:block; margin-bottom:6px; }
.species-card-name { font-size:12px; font-weight:700; }
.species-card .sci { font-size:9px; color:var(--text2); font-style:italic; margin-top:2px; }
.badge-custom {
position:absolute; top:6px; right:6px;
background:var(--yellow); color:#000;
font-size:8px; font-weight:700;
padding:2px 6px; border-radius:4px;
font-family:'Syne',sans-serif;
}

/* GRID LAYOUT */
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
.grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; }
@media(max-width:600px) {
.grid-2, .grid-3 { grid-template-columns:1fr; }
}

/* RESULTS */
.result-grid {
display:grid;
grid-template-columns: repeat(auto-fill, minmax(160px,1fr));
gap:10px;
}
.result-item {
background:var(--bg);
border:1px solid var(--border);
border-radius:10px;
padding:12px;
}
.result-item label {
font-size:10px; color:var(--text2);
display:block; margin-bottom:4px;
}
.result-item .value {
font-family:'DM Mono',monospace;
font-size:16px; font-weight:500;
color:var(--green);
}
.result-item.income .value { color:var(--blue); }
.result-item.profit .value { color:var(--yellow); }
.result-item.warning .value { color:var(--danger); }

/* WATER PARAMS SECTION */
.section-water {
background: rgba(0,153,255,0.04);
border:1px solid rgba(0,153,255,0.15);
border-radius: var(--radius);
padding:16px; margin-bottom:16px;
}
.section-zoo {
background: rgba(240,165,0,0.04);
border:1px solid rgba(240,165,0,0.15);
border-radius: var(--radius);
padding:16px; margin-bottom:16px;
}

/* BITACORA LIST */
.bit-record {
background:var(--bg);
border:1px solid var(--border);
border-radius:10px;
padding:14px; margin-bottom:10px;
position:relative;
}
.bit-record .bit-head {
display:flex; justify-content:space-between;
align-items:center; margin-bottom:8px;
}
.bit-record .bit-head span {
font-size:13px; font-weight:600;
}
.bit-record .bit-detail {
font-size:11px; color:var(--text2);
line-height:1.8;
}
.bit-record .bit-detail b { color:var(--text); }
.btn-delete {
background:transparent; border:1px solid var(--danger);
color:var(--danger); padding:4px 10px;
border-radius:6px; cursor:pointer; font-size:11px;
}

/* CHART */
.chart-container {
background:var(--bg);
border:1px solid var(--border);
border-radius:var(--radius);
padding:16px; margin-bottom:16px;
overflow-x:auto;
}
.bar-chart {
min-height:200px; position:relative;
}
.bar-row {
display:flex; align-items:center;
margin-bottom:4px; gap:8px;
}
.bar-label {
min-width:70px; font-size:10px;
color:var(--text2); text-align:right;
font-family:'DM Mono',monospace;
}
.bar-fill {
height:16px; border-radius:4px;
transition:width .3s; min-width:2px;
}
.bar-value {
font-size:10px; color:var(--text2);
font-family:'DM Mono',monospace;
min-width:50px;
}

/* TABLE */
.data-table {
width:100%; border-collapse:collapse;
font-size:11px; overflow-x:auto;
display:block;
}
.data-table th {
background:var(--surface2);
padding:10px 8px; text-align:left;
color:var(--text2); font-weight:600;
font-size:10px; white-space:nowrap;
position:sticky; top:0;
}
.data-table td {
padding:8px; border-bottom:1px solid var(--border);
white-space:nowrap;
font-family:'DM Mono',monospace;
font-size:11px;
}
.data-table tr:hover td { background:rgba(255,255,255,0.02); }

/* PARAMS TABLE */
.param-row {
display:flex; align-items:center;
padding:12px 0; border-bottom:1px solid var(--border);
gap:12px; flex-wrap:wrap;
}
.param-row .param-name {
flex:1; min-width:120px;
font-size:13px; font-weight:500;
}
.param-row .param-unit {
font-size:11px; color:var(--text2); min-width:60px;
}
.param-row .param-default {
font-size:10px; color:var(--text2);
font-family:'DM Mono',monospace;
min-width:80px;
}
.param-row input {
width:100px; padding:8px 10px;
background:var(--bg); border:1px solid var(--border);
border-radius:8px; color:var(--text);
font-family:'DM Mono',monospace;
font-size:13px; outline:none;
}
.param-row input:focus { border-color:var(--green); }

/* MINI TABS */
.mini-tabs {
display:flex; gap:6px; flex-wrap:wrap;
margin-bottom:16px;
}
.mini-tab {
padding:8px 14px; border-radius:8px;
background:var(--bg); border:1px solid var(--border);
color:var(--text2); cursor:pointer;
font-size:11px; font-weight:600;
font-family:'Syne',sans-serif;
transition:.2s;
}
.mini-tab.active {
background:var(--green); color:#000;
border-color:var(--green);
}

/* MODAL */
.modal-overlay {
display:none; position:fixed;
top:0; left:0; right:0; bottom:0;
background:rgba(0,0,0,0.7);
z-index:200; align-items:center;
justify-content:center; padding:20px;
}
.modal-overlay.show {
display:flex;
}
.modal {
background:var(--surface);
border:1px solid var(--border);
border-radius:var(--radius);
padding:28px; width:100%;
max-width:500px; max-height:90vh;
overflow-y:auto;
}
.modal h3 {
margin-bottom:20px; font-size:18px;
}

/* TOAST */
.toast-container {
position:fixed; top:20px; right:20px;
z-index:300;
}
.toast {
background:var(--surface2);
border:1px solid var(--border);
border-radius:10px;
padding:14px 20px;
margin-bottom:8px;
font-size:13px;
animation: toastIn .3s ease;
display:flex; align-items:center; gap:8px;
}
.toast.success { border-left:3px solid var(--green); }
.toast.error { border-left:3px solid var(--danger); }
.toast.info { border-left:3px solid var(--blue); }
@keyframes toastIn {
from { opacity:0; transform:translateX(40px); }
to { opacity:1; transform:translateX(0); }
}

/* SPINNER */
.spinner-overlay {
display:none; position:fixed;
top:0;left:0;right:0;bottom:0;
background:rgba(10,22,40,0.85);
z-index:250;
align-items:center; justify-content:center;
}
.spinner-overlay.show { display:flex; }
.spinner {
width:40px; height:40px;
border:3px solid var(--surface2);
border-top-color:var(--green);
border-radius:50%;
animation:spin .8s linear infinite;
}
@keyframes spin { to { transform:rotate(360deg); } }

/* FILTERS */
.filters {
display:flex; gap:10px; flex-wrap:wrap;
margin-bottom:16px;
}
.filters select, .filters input {
padding:10px 12px;
background:var(--bg); border:1px solid var(--border);
border-radius:8px; color:var(--text);
font-family:'DM Sans',sans-serif;
font-size:13px; outline:none;
}
.filters select:focus, .filters input:focus {
border-color:var(--green);
}

/* RESPONSIVE */
@media(max-width:600px) {
.header { flex-wrap:wrap; gap:8px; }
.species-grid { grid-template-columns: repeat(auto-fill, minmax(100px,1fr)); }
.result-grid { grid-template-columns: 1fr 1fr; }
.tabs { padding:0 4px; }
.tab-btn { padding:12px 10px; font-size:11px; }
}
</style>
</head>
<body>

<!-- TOAST CONTAINER -->
<div class="toast-container" id="toasts"></div>

<!-- SPINNER -->
<div class="spinner-overlay" id="spinner">
<div class="spinner"></div>
</div>

<!-- AUTH SCREEN -->
<div id="auth-screen">
<div class="auth-container">
<div class="auth-logo">
<h1>🐟 AquaCalc CR</h1>
<p>Calculadora Profesional de Acuicultura</p>
</div>
<div class="auth-tabs">
<div class="auth-tab active" onclick="switchAuthTab('login')">Ingresar</div>
<div class="auth-tab" onclick="switchAuthTab('register')">Registrarse</div>
</div>
<div id="login-form">
<div class="form-group">
<label>Correo electrónico</label>
<input type="email" id="login-email" placeholder="usuario@email.com">
</div>
<div class="form-group">
<label>Contraseña</label>
<input type="password" id="login-pass" placeholder="••••••••">
</div>
<button class="btn btn-primary" onclick="doLogin()">Ingresar</button>
<div class="auth-error" id="login-error"></div>
</div>
<div id="register-form" style="display:none">
<div class="form-group">
<label>Nombre completo</label>
<input type="text" id="reg-name" placeholder="Juan Pérez">
</div>
<div class="form-group">
<label>Nombre de finca</label>
<input type="text" id="reg-farm" placeholder="Finca El Estanque">
</div>
<div class="form-group">
<label>Correo electrónico</label>
<input type="email" id="reg-email" placeholder="usuario@email.com">
</div>
<div class="form-group">
<label>Contraseña (mín. 6 caracteres)</label>
<input type="password" id="reg-pass" placeholder="••••••••">
</div>
<button class="btn btn-primary" onclick="doRegister()">Crear Cuenta</button>
<div class="auth-error" id="reg-error"></div>
</div>
</div>
</div>

<!-- MAIN APP -->
<div id="app-screen">
<div class="header">
<div class="header-left">
<h2>🐟 AquaCalc CR</h2>
<p id="header-farm"></p>
</div>
<div class="header-right">
<div class="user-info">
<span id="header-user"></span>
<small id="header-email"></small>
</div>
<button class="btn-logout" onclick="doLogout()">Salir</button>
</div>
</div>

<div class="tabs">
<div class="tab-btn active" onclick="switchTab(0)">🧮 Calculadora</div>
<div class="tab-btn" onclick="switchTab(1)">📋 Bitácora</div>
<div class="tab-btn" onclick="switchTab(2)">📊 Seguimiento</div>
<div class="tab-btn" onclick="switchTab(3)">⚙️ Parámetros</div>
<div class="tab-btn" onclick="switchTab(4)">🐠 Mis Especies</div>
</div>

<!-- TAB 0: CALCULADORA -->
<div class="tab-content active" id="tab-0">
<div class="card">
<div class="card-title"><div class="dot" style="background:var(--green)"></div>Seleccionar Especie</div>
<div class="species-grid" id="calc-species-grid"></div>
</div>

<div class="card">
<div class="card-title"><div class="dot" style="background:var(--blue)"></div>Datos del Proyecto</div>
<div class="grid-2">
<div class="form-group">
<label id="lbl-vol">Volumen (m³)</label>
<input type="number" id="calc-vol" oninput="calcResults()" placeholder="0">
</div>
<div class="form-group">
<label>Densidad de siembra</label>
<input type="number" id="calc-dens" oninput="calcResults()" step="any" placeholder="0">
</div>
<div class="form-group">
<label>Peso inicial (g)</label>
<input type="number" id="calc-wi" oninput="calcResults()" step="any" placeholder="0">
</div>
<div class="form-group">
<label>Peso cosecha (g)</label>
<input type="number" id="calc-wf" oninput="calcResults()" step="any" placeholder="0">
</div>
<div class="form-group">
<label>Supervivencia (%)</label>
<input type="number" id="calc-surv" oninput="calcResults()" step="any" placeholder="0">
</div>
<div class="form-group">
<label>FCR</label>
<input type="number" id="calc-fcr" oninput="calcResults()" step="any" placeholder="0">
</div>
<div class="form-group">
<label>Precio alimento (₡/kg)</label>
<input type="number" id="calc-pfeed" oninput="calcResults()" placeholder="0">
</div>
<div class="form-group">
<label>Precio venta (₡/kg)</label>
<input type="number" id="calc-psale" oninput="calcResults()" placeholder="0">
</div>
</div>
</div>

<div class="card">
<div class="card-title"><div class="dot" style="background:var(--yellow)"></div>Resultados</div>
<div class="result-grid" id="calc-results"></div>
</div>

<div class="card">
<div class="card-title"><div class="dot" style="background:var(--green)"></div>Ración Diaria</div>
<div class="grid-2">
<div class="form-group">
<label>Biomasa actual del estanque (kg)</label>
<input type="number" id="calc-biom-act" oninput="calcRation()" step="any" placeholder="0">
</div>
</div>
<div class="result-grid" id="ration-results" style="margin-top:12px"></div>
</div>
</div>

<!-- TAB 1: BITÁCORA -->
<div class="tab-content" id="tab-1">
<div class="card">
<div class="card-title"><div class="dot" style="background:var(--green)"></div>Nuevo Registro</div>

<div class="grid-3" style="margin-bottom:12px">
<div class="form-group">
<label>Fecha</label>
<input type="date" id="bit-date">
</div>
<div class="form-group">
<label>Estanque</label>
<input type="text" id="bit-pond" placeholder="Ej: Estanque 1">
</div>
<div class="form-group">
<label>Especie</label>
<select id="bit-species"></select>
</div>
</div>
<div class="grid-3" style="margin-bottom:16px">
<div class="form-group">
<label>Alimento suministrado (kg)</label>
<input type="number" id="bit-feed" step="any" placeholder="0">
</div>
<div class="form-group">
<label>Mortalidades</label>
<input type="number" id="bit-mort" placeholder="0">
</div>
<div class="form-group">
<label>Peso muestreo (g)</label>
<input type="number" id="bit-weight" step="any" placeholder="0">
</div>
</div>

<div class="section-water">
<div class="card-title" style="color:var(--blue)"><div class="dot" style="background:var(--blue)"></div>Calidad de Agua</div>
<div class="grid-3">
<div class="form-group">
<label>Oxígeno disuelto (mg/L)</label>
<input type="number" id="bit-o2" step="any">
</div>
<div class="form-group">
<label>Temperatura (°C)</label>
<input type="number" id="bit-temp" step="any">
</div>
<div class="form-group">
<label>pH</label>
<input type="number" id="bit-ph" step="any">
</div>
<div class="form-group">
<label>Amonio NH₃ (mg/L)</label>
<input type="number" id="bit-nh3" step="any">
</div>
<div class="form-group">
<label>Nitrito NO₂ (mg/L)</label>
<input type="number" id="bit-no2" step="any">
</div>
<div class="form-group">
<label>Nitrato NO₃ (mg/L)</label>
<input type="number" id="bit-no3" step="any">
</div>
<div class="form-group">
<label>Alcalinidad (mg/L)</label>
<input type="number" id="bit-alk" step="any">
</div>
<div class="form-group">
<label>Dureza (mg/L)</label>
<input type="number" id="bit-hard" step="any">
</div>
</div>
</div>

<div class="section-zoo">
<div class="card-title" style="color:var(--yellow)"><div class="dot" style="background:var(--yellow)"></div>Datos Zootécnicos</div>
<div class="grid-3">
<div class="form-group">
<label>Biomasa estanque (kg)</label>
<input type="number" id="bit-biom" step="any">
</div>
<div class="form-group">
<label>N° animales estimado</label>
<input type="number" id="bit-nani">
</div>
<div class="form-group">
<label>SGR (%/día)</label>
<input type="number" id="bit-sgr" step="any">
</div>
<div class="form-group">
<label>FCR acumulado</label>
<input type="number" id="bit-fcra" step="any">
</div>
<div class="form-group">
<label>Índice condición K</label>
<input type="number" id="bit-k" step="any">
</div>
<div class="form-group">
<label>CV% uniformidad</label>
<input type="number" id="bit-cv" step="any">
</div>
</div>
</div>

<div class="form-group" style="margin-bottom:16px">
<label>Observaciones</label>
