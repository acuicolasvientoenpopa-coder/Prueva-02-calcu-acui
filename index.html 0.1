<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getAuth, createUserWithEmailAndPassword, signInWithEmailAndPassword, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-auth.js";
import { getFirestore, doc, getDoc, setDoc, updateDoc } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyBQVYs78jJcVPG34hqPwKgBZemk8mYWgQo",
  authDomain: "acuacalweb.firebaseapp.com",
  projectId: "acuacalweb",
  storageBucket: "acuacalweb.firebasestorage.app",
  messagingSenderId: "717276911914",
  appId: "1:717276911914:web:96cd11b48d17b1d31b6653"
};

const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);

// ---------- DEFAULTS ----------
const DEFAULT_SPECIES = {
  tilapia: { name:'Tilapia', sci:'O. niloticus', emoji:'🐟', density:20, dunit:'peces/m³', vunit:'m³', surv:90, fcr:1.4, rate:3, meals:3, gpd:3.5, pfeed:850, psale:2200, wi:5, wf:500 },
  trucha: { name:'Trucha', sci:'O. mykiss', emoji:'🐠', density:30, dunit:'kg/m³', vunit:'m³', surv:88, fcr:1.2, rate:2, meals:4, gpd:2.8, pfeed:1100, psale:4500, wi:10, wf:350 },
  camaron: { name:'Camarón', sci:'L. vannamei', emoji:'🦐', density:80, dunit:'ind/m²', vunit:'m²', surv:70, fcr:1.5, rate:4, meals:4, gpd:0.15, pfeed:1200, psale:8000, wi:0.1, wf:12 },
  guapote: { name:'Guapote', sci:'Parachromis dovii', emoji:'🐡', density:5, dunit:'peces/m³', vunit:'m³', surv:85, fcr:1.8, rate:3.5, meals:2, gpd:2.0, pfeed:900, psale:3500, wi:10, wf:400 },
  langostino: { name:'Langostino', sci:'M. rosenbergii', emoji:'🦞', density:8, dunit:'ind/m²', vunit:'m²', surv:65, fcr:1.8, rate:5, meals:2, gpd:0.3, pfeed:1400, psale:12000, wi:0.5, wf:40 },
  pangasio: { name:'Pangasio', sci:'P. hypophthalmus', emoji:'🐟', density:40, dunit:'peces/m³', vunit:'m³', surv:92, fcr:1.3, rate:3.5, meals:3, gpd:5.0, pfeed:780, psale:1800, wi:5, wf:800 },
  carpa: { name:'Carpa Herbívora', sci:'C. idella', emoji:'🐠', density:2, dunit:'peces/m³', vunit:'m³', surv:88, fcr:3.5, rate:6, meals:2, gpd:8.0, pfeed:200, psale:1500, wi:20, wf:1500 }
};

let currentUser = null;
let userData = { name:'', farm:'', params:{}, bitacora:[], customSpecies:[] };
let selectedCalcSpecies = null;
let editingSpeciesIdx = -1;
let currentParamSpecies = 'tilapia';
let saveTimeout = null;

// ---------- UTILS ----------
function $(id){ return document.getElementById(id); }
function showSpinner(){ $('spinner').classList.add('show'); }
function hideSpinner(){ $('spinner').classList.remove('show'); }

function toast(msg, type='success'){
  const t = document.createElement('div');
  t.className = 'toast ' + type;
  t.textContent = msg;
  $('toasts').appendChild(t);
  setTimeout(()=>t.remove(), 3000);
}

function fmt(n, dec=1){
  if(n===null||n===undefined||isNaN(n)) return '—';
  return Number(n).toLocaleString('es-CR',{minimumFractionDigits:0,maximumFractionDigits:dec});
}

function fmtMoney(n){
  if(n===null||n===undefined||isNaN(n)) return '—';
  return '₡'+Number(n).toLocaleString('es-CR',{minimumFractionDigits:0,maximumFractionDigits:0});
}

// ---------- AUTH ----------
window.switchAuthTab = function(tab){
  document.querySelectorAll('.auth-tab').forEach((t,i)=>{
    t.classList.toggle('active', (tab==='login'?i===0:i===1));
  });
  $('login-form').style.display = tab==='login'?'block':'none';
  $('register-form').style.display = tab==='register'?'block':'none';
};

window.doLogin = async function(){
  const email=$('login-email').value.trim(), pass=$('login-pass').value;
  $('login-error').textContent='';
  if(!email||!pass){$('login-error').textContent='Complete todos los campos'; return;}
  showSpinner();
  try{
    await signInWithEmailAndPassword(auth,email,pass);
  }catch(e){
    $('login-error').textContent=parseFirebaseError(e.code);
    hideSpinner();
  }
};

window.doRegister = async function(){
  const name=$('reg-name').value.trim(), farm=$('reg-farm').value.trim();
  const email=$('reg-email').value.trim(), pass=$('reg-pass').value;
  $('reg-error').textContent='';
  if(!name||!farm||!email||!pass){$('reg-error').textContent='Complete todos los campos';return;}
  if(pass.length<6){$('reg-error').textContent='Mínimo 6 caracteres';return;}
  showSpinner();
  try{
    const cred = await createUserWithEmailAndPassword(auth,email,pass);
    await setDoc(doc(db,'users',cred.user.uid),{
      name, farm, params:{}, bitacora:[], customSpecies:[]
    });
    toast('Cuenta creada exitosamente');
  }catch(e){
    $('reg-error').textContent=parseFirebaseError(e.code);
    hideSpinner();
  }
};

window.doLogout = async function(){
  await signOut(auth);
  location.reload();
};

function parseFirebaseError(code){
  const map={
    'auth/email-already-in-use':'Correo ya registrado',
    'auth/invalid-email':'Correo inválido',
    'auth/weak-password':'Contraseña muy débil',
    'auth/user-not-found':'Usuario no encontrado',
    'auth/wrong-password':'Contraseña incorrecta',
    'auth/invalid-credential':'Credenciales inválidas',
    'auth/too-many-requests':'Demasiados intentos, intente después'
  };
  return map[code]||'Error: '+code;
}

onAuthStateChanged(auth, async user=>{
  if(user){
    currentUser=user;
    showSpinner();
    try{
      const snap = await getDoc(doc(db,'users',user.uid));
      if(snap.exists()){
        const d=snap.data();
        userData.name=d.name||'';
        userData.farm=d.farm||'';
        userData.params=d.params||{};
        userData.bitacora=d.bitacora||[];
        userData.customSpecies=d.customSpecies||[];
      } else {
        await setDoc(doc(db,'users',user.uid),{
          name:'', farm:'', params:{}, bitacora:[], customSpecies:[]
        });
      }
    }catch(e){ console.error(e); }
    hideSpinner();
    showApp();
  } else {
    currentUser=null;
    $('auth-screen').style.display='flex';
    $('app-screen').style.display='none';
  }
});

// ---------- SAVE TO FIREBASE ----------
function scheduleSave(){
  clearTimeout(saveTimeout);
  saveTimeout=setTimeout(async()=>{
    if(!currentUser) return;
    try{
      await updateDoc(doc(db,'users',currentUser.uid),{
        params: userData.params,
        bitacora: userData.bitacora,
        customSpecies: userData.customSpecies
      });
    }catch(e){ console.error('Save error',e); }
  }, 800);
}

// ---------- GET ALL SPECIES ----------
function getAllSpecies(){
  const all={};
  for(const [k,v] of Object.entries(DEFAULT_SPECIES)){
    const p = userData.params[k]||{};
    all[k]={...v, ...p, _custom:false};
  }
  (userData.customSpecies||[]).forEach((cs,i)=>{
    const key='custom_'+i;
    all[key]={...cs, _custom:true, _idx:i};
  });
  return all;
}

function getSpeciesParam(key, param){
  const sp = getAllSpecies();
  if(sp[key]) return sp[key][param];
  return null;
}

// ---------- SHOW APP ----------
function showApp(){
  $('auth-screen').style.display='none';
  $('app-screen').style.display='block';
  $('header-user').textContent=userData.name||'Usuario';
  $('header-farm').textContent=userData.farm||'';
  $('header-email').textContent=currentUser.email;
  $('bit-date').value = new Date().toISOString().split('T')[0];
  renderCalcSpecies();
  populateSpeciesSelects();
  renderBitacora();
  renderParamTabs();
  renderCustomSpecies();
}

// ---------- TABS ----------
window.switchTab = function(idx){
  document.querySelectorAll('.tab-btn').forEach((t,i)=>t.classList.toggle('active',i===idx));
  document.querySelectorAll('.tab-content').forEach((t,i)=>t.classList.toggle('active',i===idx));
  if(idx===2) renderChart();
  if(idx===3) renderParamTabs();
};

// ========================
// TAB 0: CALCULADORA
// ========================
function renderCalcSpecies(){
  const grid=$('calc-species-grid');
  grid.innerHTML='';
  const spp = getAllSpecies();
  for(const [k,sp] of Object.entries(spp)){
    const card=document.createElement('div');
    card.className='species-card'+(selectedCalcSpecies===k?' selected':'');
    card.innerHTML=`
      <span class="emoji">${sp.emoji}</span>
      <div class="species-card-name">${sp.name}</div>
      <div class="sci">${sp.sci}</div>
      ${sp._custom?'<span class="badge-custom">CUSTOM</span>':''}
    `;
    card.onclick=()=>selectCalcSpecies(k);
    grid.appendChild(card);
  }
}

function selectCalcSpecies(key){
  selectedCalcSpecies=key;
  const sp=getAllSpecies()[key];
  if(!sp) return;
  $('calc-vol').value='';
  $('calc-dens').value=sp.density;
  $('calc-wi').value=sp.wi;
  $('calc-wf').value=sp.wf;
  $('calc-surv').value=sp.surv;
  $('calc-fcr').value=sp.fcr;
  $('calc-pfeed').value=sp.pfeed;
  $('calc-psale').value=sp.psale;
  $('lbl-vol').textContent = sp.vunit==='m²' ? 'Área (m²)' : 'Volumen (m³)';
  renderCalcSpecies();
  calcResults();
}
window.selectCalcSpecies = selectCalcSpecies;

function calcResults(){
  const vol=parseFloat($('calc-vol').value)||0;
  const dens=parseFloat($('calc-dens').value)||0;
  const wi=parseFloat($('calc-wi').value)||0;
  const wf=parseFloat($('calc-wf').value)||0;
  const surv=(parseFloat($('calc-surv').value)||0)/100;
  const fcr=parseFloat($('calc-fcr').value)||0;
  const pfeed=parseFloat($('calc-pfeed').value)||0;
  const psale=parseFloat($('calc-psale').value)||0;

  let sp = selectedCalcSpecies ? getAllSpecies()[selectedCalcSpecies] : null;
  let gpd = sp ? sp.gpd : 3;

  const totalAnimals = vol * dens;
  const biomI = totalAnimals * wi / 1000;
  const animHarv = totalAnimals * surv;
  const biomH = animHarv * wf / 1000;
  const gainKg = biomH - biomI;
  const feedTotal = gainKg * fcr;
  const costFeed = feedTotal * pfeed;
  const income = biomH * psale;
  const profit = income - costFeed;
  const days = gpd > 0 ? (wf - wi) / gpd : 0;
  const costPerKg = biomH > 0 ? costFeed / biomH : 0;

  const r = $('calc-results');
  r.innerHTML = `
    ${ri('Total animales', fmt(totalAnimals,0))}
    ${ri('Biomasa inicial', fmt(biomI,1)+' kg')}
    ${ri('Animales a cosecha', fmt(animHarv,0))}
    ${ri('Biomasa cosecha', fmt(biomH,1)+' kg','income')}
    ${ri('Alimento total', fmt(feedTotal,1)+' kg')}
    ${ri('Costo alimento', fmtMoney(costFeed),'warning')}
    ${ri('Ingreso bruto', fmtMoney(income),'income')}
    ${ri('Utilidad', fmtMoney(profit), profit>=0?'profit':'warning')}
    ${ri('Días estimados', fmt(days,0)+' días')}
    ${ri('GPD', fmt(gpd,2)+' g/día')}
    ${ri('Costo/kg producido', fmtMoney(costPerKg))}
  `;
  calcRation();
}
window.calcResults = calcResults;

function calcRation(){
  const biomAct = parseFloat($('calc-biom-act').value)||0;
  let sp = selectedCalcSpecies ? getAllSpecies()[selectedCalcSpecies] : null;
  const rate = sp ? sp.rate : 3;
  const meals = sp ? sp.meals : 3;
  const rationDay = biomAct * (rate/100);
  const rationMeal = meals > 0 ? rationDay / meals : 0;
  $('ration-results').innerHTML = `
    ${ri('Tasa alimentación', fmt(rate,1)+'%')}
    ${ri('Ración/día', fmt(rationDay,2)+' kg')}
    ${ri('Ración/comida', fmt(rationMeal,2)+' kg')}
    ${ri('Comidas/día', fmt(meals,0))}
  `;
}
window.calcRation = calcRation;

function ri(label, value, cls=''){
  return `<div class="result-item ${cls}"><label>${label}</label><div class="value mono">${value}</div></div>`;
}

// ========================
// TAB 1: BITÁCORA
// ========================
function populateSpeciesSelects(){
  const spp=getAllSpecies();
  const opts = Object.entries(spp).map(([k,s])=>`<option value="${k}">${s.emoji} ${s.name}</option>`).join('');
  $('bit-species').innerHTML = opts;
  // filters
  const bitPonds=[...new Set(userData.bitacora.map(b=>b.pond))];
  $('bit-filter-pond').innerHTML='<option value="">Todos los estanques</option>'+bitPonds.map(p=>`<option value="${p}">${p}</option>`).join('');
  const bitSp=[...new Set(userData.bitacora.map(b=>b.species))];
  $('bit-filter-sp').innerHTML='<option value="">Todas las especies</option>'+bitSp.map(s=>`<option value="${s}">${s}</option>`).join('');
  // seg filters
  $('seg-pond').innerHTML='<option value="">Todos estanques</option>'+bitPonds.map(p=>`<option value="${p}">${p}</option>`).join('');
  $('seg-sp').innerHTML='<option value="">Todas especies</option>'+bitSp.map(s=>`<option value="${s}">${s}</option>`).join('');
}

window.saveBitacora = function(){
  const record={
    date: $('bit-date').value,
    pond: $('bit-pond').value.trim(),
    species: $('bit-species').value,
    feed: parseFloat($('bit-feed').value)||0,
    mort: parseInt($('bit-mort').value)||0,
    weight: parseFloat($('bit-weight').value)||0,
    o2: parseFloat($('bit-o2').value)||null,
    temp: parseFloat($('bit-temp').value)||null,
    ph: parseFloat($('bit-ph').value)||null,
    nh3: parseFloat($('bit-nh3').value)||null,
    no2: parseFloat($('bit-no2').value)||null,
    no3: parseFloat($('bit-no3').value)||null,
    alk: parseFloat($('bit-alk').value)||null,
    hard: parseFloat($('bit-hard').value)||null,
    biom: parseFloat($('bit-biom').value)||null,
    nani: parseInt($('bit-nani').value)||null,
    sgr: parseFloat($('bit-sgr').value)||null,
    fcra: parseFloat($('bit-fcra').value)||null,
    k: parseFloat($('bit-k').value)||null,
    cv: parseFloat($('bit-cv').value)||null,
    obs: $('bit-obs').value.trim(),
    ts: Date.now()
  };
  if(!record.date||!record.pond){
    toast('Fecha y estanque son requeridos','error');
    return;
  }
  userData.bitacora.push(record);
  scheduleSave();
  toast('Registro guardado');
  // Clear some fields
  ['bit-feed','bit-mort','bit-weight','bit-o2','bit-temp','bit-ph','bit-nh3','bit-no2','bit-no3','bit-alk','bit-hard','bit-biom','bit-nani','bit-sgr','bit-fcra','bit-k','bit-cv','bit-obs'].forEach(id=>{
    const el=$(id); if(el) el.value='';
  });
  populateSpeciesSelects();
  renderBitacora();
};

function renderBitacora(){
  const fp=$('bit-filter-pond').value;
  const fs=$('bit-filter-sp').value;
  let records=[...userData.bitacora];
  if(fp) records=records.filter(r=>r.pond===fp);
  if(fs) records=records.filter(r=>r.species===fs);
  records.sort((a,b)=>b.ts-a.ts);
  const spp=getAllSpecies();
  const list=$('bit-list');
  if(!records.length){
    list.innerHTML='<p style="color:var(--text2);font-size:13px;text-align:center;padding:20px">No hay registros</p>';
    return;
  }
  list.innerHTML=records.map((r,i)=>{
    const origIdx=userData.bitacora.indexOf(r);
    const sp=spp[r.species];
    const spName=sp?sp.emoji+' '+sp.name:r.species;
    let details=[];
    if(r.feed) details.push(`<b>Alimento:</b> ${r.feed}kg`);
    if(r.mort) details.push(`<b>Mort:</b> ${r.mort}`);
    if(r.weight) details.push(`<b>Peso:</b> ${r.weight}g`);
    if(r.o2!==null) details.push(`<b>O₂:</b> ${r.o2}`);
    if(r.temp!==null) details.push(`<b>T°:</b> ${r.temp}`);
    if(r.ph!==null) details.push(`<b>pH:</b> ${r.ph}`);
    if(r.nh3!==null) details.push(`<b>NH₃:</b> ${r.nh3}`);
    if(r.no2!==null) details.push(`<b>NO₂:</b> ${r.no2}`);
    if(r.no3!==null) details.push(`<b>NO₃:</b> ${r.no3}`);
    if(r.biom!==null) details.push(`<b>Biom:</b> ${r.biom}kg`);
    if(r.sgr!==null) details.push(`<b>SGR:</b> ${r.sgr}`);
    if(r.fcra!==null) details.push(`<b>FCRa:</b> ${r.fcra}`);
    if(r.k!==null) details.push(`<b>K:</b> ${r.k}`);
    if(r.cv!==null) details.push(`<b>CV:</b> ${r.cv}%`);
    if(r.obs) details.push(`<b>Obs:</b> ${r.obs}`);
    return `<div class="bit-record">
      <div class="bit-head">
        <span>${r.date} · ${r.pond} · ${spName}</span>
        <button class="btn-delete" onclick="deleteBit(${origIdx})">🗑 Eliminar</button>
      </div>
      <div class="bit-detail">${details.join(' &nbsp;|&nbsp; ')}</div>
    </div>`;
  }).join('');
}

window.deleteBit = function(idx){
  if(!confirm('¿Eliminar este registro?')) return;
  userData.bitacora.splice(idx,1);
  scheduleSave();
  toast('Registro eliminado','info');
  populateSpeciesSelects();
  renderBitacora();
};

// ========================
// TAB 2: SEGUIMIENTO
// ========================
function renderChart(){
  const fp=$('seg-pond').value;
  const fs=$('seg-sp').value;
  const param=$('seg-param').value;
  let records=[...userData.bitacora];
  if(fp) records=records.filter(r=>r.pond===fp);
  if(fs) records=records.filter(r=>r.species===fs);
  records.sort((a,b)=>(a.ts||0)-(b.ts||0));
  records=records.slice(-30);

  const colors=['var(--green)','var(--blue)','var(--yellow)'];
  const vals=records.map(r=>r[param]).filter(v=>v!==null&&v!==undefined&&!isNaN(v));
  const maxVal=vals.length?Math.max(...vals):1;

  const chart=$('bar-chart');
  if(!records.length){
    chart.innerHTML='<p style="color:var(--text2);text-align:center;padding:40px;font-size:13px">Sin datos para graficar</p>';
  } else {
    chart.innerHTML=records.map((r,i)=>{
      const v=r[param];
      if(v===null||v===undefined) return '';
      const pct=maxVal>0?(v/maxVal*100):0;
      const c=colors[i%3];
      return `<div class="bar-row">
        <div class="bar-label">${r.date?r.date.slice(5):''}</div>
        <div class="bar-fill" style="width:${Math.max(pct,1)}%;background:${c}"></div>
        <div class="bar-value">${fmt(v,2)}</div>
      </div>`;
    }).join('');
  }

  // Table
  const tbody=$('seg-table').querySelector('tbody');
  tbody.innerHTML=records.map(r=>`<tr>
    <td>${r.date||''}</td><td>${r.pond||''}</td><td>${r.species||''}</td>
    <td>${r.o2??''}</td><td>${r.temp??''}</td><td>${r.ph??''}</td>
    <td>${r.nh3??''}</td><td>${r.no2??''}</td><td>${r.no3??''}</td>
    <td>${r.alk??''}</td><td>${r.hard??''}</td><td>${r.biom??''}</td>
    <td>${r.weight??''}</td><td>${r.sgr??''}</td><td>${r.fcra??''}</td>
    <td>${r.k??''}</td><td>${r.cv??''}</td><td>${r.mort??''}</td>
  </tr>`).join('');
}
window.renderChart = renderChart;

// ========================
// TAB 3: PARÁMETROS
// ========================
function renderParamTabs(){
  const spp=getAllSpecies();
  const tabs=$('param-tabs');
  tabs.innerHTML='';
  for(const [k,sp] of Object.entries(spp)){
    const t=document.createElement('div');
    t.className='mini-tab'+(currentParamSpecies===k?' active':'');
    t.textContent=sp.emoji+' '+sp.name;
    t.onclick=()=>{ currentParamSpecies=k; renderParamTabs(); };
    tabs.appendChild(t);
  }
  renderParamEditor();
}

function renderParamEditor(){
  const key=currentParamSpecies;
  const spp=getAllSpecies();
  const sp=spp[key];
  if(!sp){ $('param-editor').innerHTML=''; return; }
  const def = sp._custom ? sp : DEFAULT_SPECIES[key];
  const fields=[
    {f:'density',label:'Densidad',unit:sp.dunit||'u'},
    {f:'surv',label:'Supervivencia',unit:'%'},
    {f:'fcr',label:'FCR',unit:'ratio'},
    {f:'rate',label:'Tasa alimentación',unit:'%/día'},
    {f:'meals',label:'Comidas/día',unit:'veces'},
    {f:'gpd',label:'GPD',unit:'g/día'},
    {f:'pfeed',label:'Precio alimento',unit:'₡/kg'},
    {f:'psale',label:'Precio venta',unit:'₡/kg'},
    {f:'wi',label:'Peso inicial',unit:'g'},
    {f:'wf',label:'Peso cosecha',unit:'g'},
  ];
  $('param-editor').innerHTML = fields.map(fd=>{
    const curVal = sp[fd.f];
    const defVal = def?def[fd.f]:'';
    return `<div class="param-row">
      <div class="param-name">${fd.label}</div>
      <div class="param-unit">${fd.unit}</div>
      <input type="number" step="any" value="${curVal??''}" onchange="updateParam('${key}','${fd.f}',this.value)">
      <div class="param-default">def: ${defVal}</div>
    </div>`;
  }).join('');
}

window.updateParam = function(speciesKey, field, value){
  const v=parseFloat(value);
  if(isNaN(v)) return;
  // Check if custom species
  const spp=getAllSpecies();
  const sp=spp[speciesKey];
  if(sp && sp._custom){
    const idx=sp._idx;
    userData.customSpecies[idx][field]=v;
  } else {
    if(!userData.params[speciesKey]) userData.params[speciesKey]={};
    userData.params[speciesKey][field]=v;
  }
  scheduleSave();
  toast('Parámetro actualizado','info');
  // Refresh calc if same species
  if(selectedCalcSpecies===speciesKey) selectCalcSpecies(speciesKey);
};

window.resetParams = function(){
  if(!confirm('¿Restaurar todos los parámetros a valores por defecto?')) return;
  userData.params={};
  scheduleSave();
  toast('Parámetros restaurados');
  renderParamTabs();
  if(selectedCalcSpecies) selectCalcSpecies(selectedCalcSpecies);
};

// ========================
// TAB 4: CUSTOM SPECIES
// ========================
function renderCustomSpecies(){
  const list=$('custom-species-list');
  const customs=userData.customSpecies||[];
  if(!customs.length){
    list.innerHTML='<p style="color:var(--text2);font-size:13px;text-align:center;padding:20px">No tienes especies personalizadas</p>';
  } else {
    list.innerHTML=customs.map((cs,i)=>`
      <div class="card" style="background:var(--bg)">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
          <div>
            <span style="font-size:24px">${cs.emoji}</span>
            <b style="margin-left:8px">${cs.name}</b>
            <i style="color:var(--text2);font-size:11px;margin-left:6px">${cs.sci}</i>
            <span class="badge-custom" style="position:static;margin-left:8px">CUSTOM</span>
          </div>
          <div style="display:flex;gap:6px">
            <button class="btn btn-secondary btn-small" onclick="editCustomSpecies(${i})">✏️</button>
            <button class="btn-delete" onclick="deleteCustomSpecies(${i})">🗑</button>
          </div>
        </div>
        <div style="font-size:11px;color:var(--text2);line-height:2">
          Densidad: <b>${cs.density} ${cs.dunit}</b> · Surv: <b>${cs.surv}%</b> · FCR: <b>${cs.fcr}</b> · GPD: <b>${cs.gpd}g</b> · Tasa: <b>${cs.rate}%</b> · Comidas: <b>${cs.meals}</b><br>
          Alimento: <b>₡${cs.pfeed}/kg</b> · Venta: <b>₡${cs.psale}/kg</b> · Peso: <b>${cs.wi}g → ${cs.wf}g</b>
        </div>
      </div>
    `).join('');
  }
  $('btn-new-species').style.display = customs.length>=3?'none':'inline-block';
}

window.openSpeciesModal = function(idx){
  editingSpeciesIdx = idx!==undefined ? idx : -1;
  $('modal-species-title').textContent = editingSpeciesIdx>=0 ? 'Editar Especie' : 'Nueva Especie';
  if(editingSpeciesIdx>=0){
    const cs=userData.customSpecies[editingSpeciesIdx];
    $('sp-name').value=cs.name||'';
    $('sp-sci').value=cs.sci||'';
    $('sp-emoji').value=cs.emoji||'';
    $('sp-dens').value=cs.density||'';
    $('sp-dunit').value=cs.dunit||'peces/m³';
    $('sp-vunit').value=cs.vunit||'m³';
    $('sp-surv').value=cs.surv||'';
    $('sp-fcr').value=cs.fcr||'';
    $('sp-rate').value=cs.rate||'';
    $('sp-meals').value=cs.meals||'';
    $('sp-gpd').value=cs.gpd||'';
    $('sp-pfeed').value=cs.pfeed||'';
    $('sp-psale').value=cs.psale||'';
    $('sp-wi').value=cs.wi||'';
    $('sp-wf').value=cs.wf||'';
  } else {
    ['sp-name','sp-sci','sp-emoji','sp-dens','sp-surv','sp-fcr','sp-rate','sp-meals','sp-gpd','sp-pfeed','sp-psale','sp-wi','sp-wf'].forEach(id=>$(id).value='');
    $('sp-dunit').value='peces/m³';
    $('sp-vunit').value='m³';
  }
  $('species-modal').classList.add('show');
};

window.closeSpeciesModal = function(){
  $('species-modal').classList.remove('show');
};

window.editCustomSpecies = function(idx){
  openSpeciesModal(idx);
};

window.deleteCustomSpecies = function(idx){
  if(!confirm('¿Eliminar esta especie?')) return;
  userData.customSpecies.splice(idx,1);
  scheduleSave();
  toast('Especie eliminada','info');
  refreshAll();
};

window.saveCustomSpecies = function(){
  const cs={
    name: $('sp-name').value.trim(),
    sci: $('sp-sci').value.trim(),
    emoji: $('sp-emoji').value.trim()||'🐟',
    density: parseFloat($('sp-dens').value)||10,
    dunit: $('sp-dunit').value,
    vunit: $('sp-vunit').value,
    surv: parseFloat($('sp-surv').value)||80,
    fcr: parseFloat($('sp-fcr').value)||1.5,
    rate: parseFloat($('sp-rate').value)||3,
    meals: parseInt($('sp-meals').value)||3,
    gpd: parseFloat($('sp-gpd').value)||2,
    pfeed: parseFloat($('sp-pfeed').value)||800,
    psale: parseFloat($('sp-psale').value)||2000,
    wi: parseFloat($('sp-wi').value)||5,
    wf: parseFloat($('sp-wf').value)||500
  };
  if(!cs.name){toast('Nombre requerido','error');return;}
  if(!userData.customSpecies) userData.customSpecies=[];
  if(editingSpeciesIdx>=0){
    userData.customSpecies[editingSpeciesIdx]=cs;
  } else {
    if(userData.customSpecies.length>=3){toast('Máximo 3 especies','error');return;}
    userData.customSpecies.push(cs);
  }
  scheduleSave();
  toast(editingSpeciesIdx>=0?'Especie actualizada':'Especie creada');
  closeSpeciesModal();
  refreshAll();
};

function refreshAll(){
  renderCalcSpecies();
  populateSpeciesSelects();
  renderBitacora();
  renderParamTabs();
  renderCustomSpecies();
}

</script>
</body>
</html>
